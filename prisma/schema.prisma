generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String          @id @default(cuid())
  clerkId              String          @unique
  email                String          @unique
  stripeCustomerId     String?         @unique
  stripeSubscriptionId String?
  subscriptionStatus   String?
  tier                 String          @default("free")
  isLifetimePro        Boolean         @default(false)
  proExpiresAt         DateTime?
  isLifetimeMax        Boolean         @default(false)
  maxExpiresAt         DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  redemptions          RedemptionLog[]
}

model PromoCode {
  id          String          @id @default(cuid())
  code        String          @unique
  type        String
  maxUses     Int
  usedCount   Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  redemptions RedemptionLog[]
}

model RedemptionLog {
  id          String    @id @default(cuid())
  userId      String
  promoCodeId String
  redeemedAt  DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [clerkId])
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
}

model Signal {
  id             String          @id @default(cuid())
  ticker         String
  companyName    String
  signalType     String
  entryZoneLow   Float
  entryZoneHigh  Float
  targetPrice    Float
  stopLoss       Float
  confidence     Float
  timeHorizon    String
  thesis         String
  aiSummary      String
  sector         String
  signalCategory String          @default("large_cap")
  // Server-assigned at generation time — replaces client-side regex parsing
  // of the free-text timeHorizon string (which orphaned real signals, e.g.
  // "1-3 months" matched none of isSwingTrade/isLongTerm/isIntraday/
  // is1to3Days). One of: 'intraday' | 'days_1_3' | 'swing' | 'long_term' |
  // 'momentum'. 'momentum' is populated only by the real intraday spike
  // scanner (isMomentumSpike below) — never backfilled onto pre-existing
  // signals and never assigned by the daily/options/intraday crons.
  timeframeCategory String?
  marketCap      Float           @default(0)
  bestEntryTime  String?
  expectedMove   String?
  catalyst       String?
  // Real intraday spike detection (volume + volatility, quantitatively gated
  // — not the old client-side isMomentum(BUY && confidence>=75) mislabeling).
  // Distinct from that legacy tab so real and fake "momentum" signals never
  // mix while the old classifier still exists.
  isMomentumSpike  Boolean        @default(false)
  outcome          String?
  outcomeCheckedAt DateTime?
  outcomePrice     Float?
  isActive       Boolean         @default(true)
  autoGenerated  Boolean         @default(false)
  signalDate     DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  trackedBy      TrackedSignal[]
}

model InsiderTrade {
  id             String   @id @default(cuid())
  companyName    String
  ticker         String
  insiderName    String
  insiderTitle   String
  tradeType      String   @default("BUY")
  shares         Int
  pricePerShare  Float
  totalValue     Float
  filingDate     DateTime
  tradeDate      DateTime
  formType       String   @default("4")
  secLink        String   @default("")
  aiSignificance String   @default("MEDIUM")
  aiCommentary   String   @default("")
  createdAt      DateTime @default(now())

  @@index([ticker])
  @@index([tradeDate])
  @@index([createdAt])
}

model OptionsSignal {
  id             String   @id @default(cuid())
  ticker         String
  companyName    String
  contractType   String
  strikePrice    Float
  expirationDate String
  premiumEstimate Float
  confidence     Float
  reasoning      String
  summary        String
  riskLevel      String   @default("Medium")
  isActive       Boolean  @default(true)
  autoGenerated  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PoliticianTrade {
  id              String   @id @default(cuid())
  externalId      String   @unique
  politicianName  String
  party           String
  chamber         String   @default("House")
  ticker          String
  companyName     String
  tradeType       String
  amountRange     String
  tradedAt        DateTime
  filedAt         DateTime
  aiCommentary    String   @default("")
  significance    String   @default("Low")
  fetchedAt       DateTime @default(now())
}

model NewsArticle {
  id          String   @id @default(cuid())
  finnhubId   Int      @unique
  headline    String
  summary     String
  source      String
  url         String
  imageUrl    String   @default("")
  publishedAt DateTime
  sentiment   String   @default("neutral")
  confidence  Int      @default(50)
  fetchedAt   DateTime @default(now())
}

model SectorSnapshot {
  id        String   @id @default(cuid())
  sector    String   @unique
  symbol    String
  price     Float    @default(0)
  change    Float    @default(0)
  changeAmt Float    @default(0)
  high52w   Float    @default(0)
  low52w    Float    @default(0)
  updatedAt DateTime @updatedAt
}

model MarketSummary {
  id        String   @id @default(cuid())
  singleton String   @unique @default("main")
  content   String
  updatedAt DateTime @updatedAt
}

model CalendarEntry {
  id           String   @id @default(cuid())
  symbol       String
  date         String
  hour         String   @default("")
  epsEstimate  Float?
  epsActual    Float?
  quarter      Int?
  year         Int?
  impactRating String   @default("Low")
  fetchedAt    DateTime @default(now())

  @@unique([symbol, date])
}

model SignalGenerationLog {
  id          String   @id @default(cuid())
  generatedAt DateTime @default(now())
  signalCount Int      @default(0)
  status      String   @default("success")
  error       String?
}

model TrackedSignal {
  id          String    @id @default(cuid())
  userId      String
  signalId    String
  signal      Signal    @relation(fields: [signalId], references: [id])
  ticker      String
  entryPrice  Float?
  notes       String?
  status      String    @default("watching")
  outcome     String?
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  @@unique([userId, signalId])
}

model ForumPost {
  id          String       @id @default(cuid())
  userId      String
  authorName  String
  authorTier  String       @default("free")
  title       String
  content     String       @db.Text
  isPinned    Boolean      @default(false)
  isLocked    Boolean      @default(false)
  upvotes     Int          @default(0)
  downvotes   Int          @default(0)
  replyCount  Int          @default(0)
  flagCount   Int          @default(0)
  isHidden    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  replies     ForumReply[]
}

model ForumReply {
  id          String    @id @default(cuid())
  postId      String
  post        ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  authorName  String
  authorTier  String    @default("free")
  content     String    @db.Text
  upvotes     Int       @default(0)
  flagCount   Int       @default(0)
  isHidden    Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model ForumVote {
  id         String   @id @default(cuid())
  userId     String
  targetId   String
  targetType String
  voteType   String
  createdAt  DateTime @default(now())

  @@unique([userId, targetId, targetType])
}

model ForumFlag {
  id         String   @id @default(cuid())
  userId     String
  targetId   String
  targetType String
  reason     String   @default("")
  createdAt  DateTime @default(now())
}

model AlertPreferences {
  id                  String   @id @default(cuid())
  clerkId             String   @unique
  newSignalAlert      Boolean  @default(true)
  highConfidenceAlert Boolean  @default(true)
  confidenceThreshold Int      @default(75)
  dailyDigest         Boolean  @default(false)
  earningsWarning     Boolean  @default(true)
  emailAlerts         Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model GeneratedContent {
  id           String    @id @default(cuid())
  weekOf       String
  type         String
  subtype      String    @default("")
  day          Int       @default(0)
  content      String    @db.Text
  metadata     String    @default("{}")
  contextNote  String    @default("")
  scheduledFor DateTime?
  generatedAt  DateTime  @default(now())
  usedAt       DateTime?
  performance  String?
}

model VideoRender {
  id          String    @id @default(cuid())
  templateId  String
  renderId    String    @unique
  bucketName  String
  awsRegion   String    @default("us-east-1")
  status      String    @default("rendering") // rendering | done | failed
  progress    Float     @default(0)
  outputUrl   String?
  errorMsg    String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  deviceInfo   String   @default("")
  ipAddress    String   @default("")
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([lastActiveAt])
}

model HealthCheck {
  id        String   @id @default(cuid())
  status    String // "pass" | "warn" | "fail"
  results   String   @db.Text // JSON array of individual check results
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model WebhookLog {
  id         String   @id @default(cuid())
  source     String   @default("stripe")
  eventType  String
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

model TrialRecord {
  id                String   @id @default(cuid())
  email             String
  userId            String
  deviceFingerprint String   @default("")
  ipAddress         String   @default("")
  trialStartedAt    DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([email])
  @@index([deviceFingerprint])
  @@index([userId])
}
