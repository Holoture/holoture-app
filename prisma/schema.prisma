generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String          @id @default(cuid())
  clerkId              String          @unique
  email                String          @unique
  stripeCustomerId     String?         @unique
  stripeSubscriptionId String?
  subscriptionStatus   String?
  tier                 String          @default("free")
  isLifetimePro        Boolean         @default(false)
  proExpiresAt         DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  redemptions          RedemptionLog[]
}

model PromoCode {
  id          String          @id @default(cuid())
  code        String          @unique
  type        String
  maxUses     Int
  usedCount   Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  redemptions RedemptionLog[]
}

model RedemptionLog {
  id          String    @id @default(cuid())
  userId      String
  promoCodeId String
  redeemedAt  DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [clerkId])
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id])
}

model Signal {
  id            String   @id @default(cuid())
  ticker        String
  companyName   String
  signalType    String
  entryZoneLow  Float
  entryZoneHigh Float
  targetPrice   Float
  stopLoss      Float
  confidence    Int
  timeHorizon   String
  thesis        String
  aiSummary     String
  sector        String
  isActive      Boolean  @default(true)
  signalDate    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AlertPreferences {
  id                  String   @id @default(cuid())
  clerkId             String   @unique
  newSignalAlert      Boolean  @default(true)
  highConfidenceAlert Boolean  @default(true)
  confidenceThreshold Int      @default(75)
  dailyDigest         Boolean  @default(false)
  earningsWarning     Boolean  @default(true)
  emailAlerts         Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
